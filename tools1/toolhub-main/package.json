{\n  "name": "toolhub",\n  "description": "A unified platform combining URL Hub dashboard and Nature Toolbox utilities",\n  "version": "1.0.0",\n  "type": "module",\n  "private": true,\n  "scripts": {\n    "dev": "npm run dev:dashboard",\n    "dev:dashboard": "cd packages/dashboard && npm run dev",\n    "dev:tools": "cd packages/tools && npm run dev",\n    "dev:all": "concurrently \"npm run dev:dashboard\" \"npm run dev:tools\"",\n    "build": "npm run build:dashboard && npm run build:tools",\n    "build:dashboard": "cd packages/dashboard && npm run build",\n    "build:tools": "cd packages/tools && npm run build",\n    "preview": "npm run preview:dashboard",\n    "preview:dashboard": "cd packages/dashboard && npm run preview",\n    "preview:tools": "cd packages/tools && npm run preview",\n    "lint": "cd packages/tools && npm run lint"\n  },\n  "workspaces": ["packages/dashboard", "packages/tools"],\n  "devDependencies": {\n    "concurrently": "^8.2.0"\n  }\n}